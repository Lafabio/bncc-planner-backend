# Chave de acesso do Mercado Pago (Access Token)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI

# URL base do seu backend (para webhooks e callbacks)
BACKEND_URL=https://seu-backend.railway.app

# Porta do servidor (local)
PORT=3000

# Segredo para validar webhooks (opcional, mas recomendado)
WEBHOOK_SECRET=seu_segredo_aqui
